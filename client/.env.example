# MuseForge client (Next.js) — copy to client/.env.local

# Backend API base URL (no trailing slash)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Supabase (browser-safe anon key only)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Stripe publishable key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# LiveCounter stays fully hidden until total_completed reaches this number
# (weak social proof below the threshold). Default in code is 50 if unset.
NEXT_PUBLIC_COUNTER_THRESHOLD=100
