# MuseForge configuration
#
# Leave the API keys empty to run in DEMO mode: the full multi-agent pipeline
# runs offline with placeholder assets so you can try the product instantly.

# --- AI / media providers (optional in demo mode) ---
MUAPI_KEY=
ANTHROPIC_API_KEY=

# Force demo mode even if MUAPI_KEY is set
MUSEFORGE_DEMO=

# --- Server ---
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
MUSEFORGE_JOBS_DIR=/tmp/museforge_jobs
# Rough seconds-per-scene used by the /api/estimate endpoint
MUSEFORGE_SECONDS_PER_SCENE=75

# --- Client (production) ---
# Where the Next.js server proxies /api/* requests
API_URL=http://localhost:8000
