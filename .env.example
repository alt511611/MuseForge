# MuseForge — tüm ortam değişkenleri
#
# API anahtarları boş bırakılırsa DEMO modu etkin olur.

# ── AI / Medya sağlayıcılar ───────────────────────────────────────────────────
MUAPI_KEY=
ANTHROPIC_API_KEY=
MUSEFORGE_DEMO=                         # "1" / "true" ile demo modu zorla
# Kling O1 HD mode string for Pro plan (default "professional"). If MuAPI
# returns 404/422 for this value, the generator silently retries with "standard".
MUAPI_VIDEO_PRO_MODE=professional
# Optional model endpoint override (default kling-o1-standard-image-to-video)
# MUAPI_VIDEO_MODEL=kling-o1-standard-image-to-video

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key   # sadece backend
SUPABASE_ANON_KEY=your-anon-key              # backend referansı

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Ürün/fiyat ID'leri (Stripe Dashboard → Products'tan alın)
STRIPE_PRICE_CREATOR=price_creator_id_here   # $49/mo — 120 credits
STRIPE_PRICE_PRO=price_pro_id_here           # $99/mo — 300 credits
# One-time credit packages (mode=payment, not subscription)
STRIPE_PRICE_CREDITS_SMALL=price_credits_small_id    # e.g. $9 — 20 credits
STRIPE_PRICE_CREDITS_MEDIUM=price_credits_medium_id  # e.g. $19 — 60 credits
STRIPE_PRICE_CREDITS_LARGE=price_credits_large_id    # e.g. $39 — 150 credits

# ── Sunucu ────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
MUSEFORGE_JOBS_DIR=/tmp/museforge_jobs
MUSEFORGE_SECONDS_PER_SCENE=75

# ── Stale job reaper (backend) ───────────────────────────────────────────────
# queued/running jobs older than this many minutes (by updated_at) are marked
# failed as "Orphaned (server restart or timeout)". Default 45.
MUSEFORGE_STALE_JOB_TIMEOUT_MINUTES=45
# Hard timeout for a single pipeline.run() (seconds). Default 1200 = 20 minutes.
MUSEFORGE_PIPELINE_HARD_TIMEOUT=1200

# ── Client (Next.js NEXT_PUBLIC_ = tarayıcıya açık) ─────────────────────────
API_URL=http://localhost:8000
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# LiveCounter stays hidden until total_completed reaches this (see client/.env.example)
NEXT_PUBLIC_COUNTER_THRESHOLD=100
