# MuseForge — tüm ortam değişkenleri
#
# API anahtarları boş bırakılırsa DEMO modu etkin olur.

# ── AI / Medya sağlayıcılar ───────────────────────────────────────────────────
MUAPI_KEY=
ANTHROPIC_API_KEY=
MUSEFORGE_DEMO=                         # "1" / "true" ile demo modu zorla

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key   # sadece backend
SUPABASE_ANON_KEY=your-anon-key              # backend referansı

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Ürün/fiyat ID'leri (Stripe Dashboard → Products'tan alın)
STRIPE_PRICE_CREATOR=price_creator_id_here
STRIPE_PRICE_PRO=price_pro_id_here

# ── Sunucu ────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
MUSEFORGE_JOBS_DIR=/tmp/museforge_jobs
MUSEFORGE_SECONDS_PER_SCENE=75

# ── Client (Next.js NEXT_PUBLIC_ = tarayıcıya açık) ─────────────────────────
API_URL=http://localhost:8000
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
