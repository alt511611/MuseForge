# MuseForge — tüm ortam değişkenleri
#
# API anahtarları boş bırakılırsa DEMO modu etkin olur (placeholder varlıklarla
# çalışır, API anahtarı gerekmez).

# ── AI / Medya sağlayıcılar (demo modda isteğe bağlı) ────────────────────────
MUAPI_KEY=
ANTHROPIC_API_KEY=

# Demo modunu API key olsa bile zorla açmak için:
MUSEFORGE_DEMO=

# ── Supabase (Auth + DB) ──────────────────────────────────────────────────────
# Bu değerleri Supabase Dashboard → Project Settings → API bölümünden alın.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key   # Sadece backend — asla frontend'e açma

# ── Sunucu ───────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
MUSEFORGE_JOBS_DIR=/tmp/museforge_jobs
# Saniye/sahne tahmini (/api/estimate için)
MUSEFORGE_SECONDS_PER_SCENE=75

# ── İstemci (Next.js public env'ler) ─────────────────────────────────────────
# Production'da API_URL'yi Render servis URL'nize ayarlayın
API_URL=http://localhost:8000
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key   # Güvenli — tarayıcıya açılabilir
